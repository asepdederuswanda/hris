# =============================================================================
# HRIS Platform - Environment Configuration
# =============================================================================
# Copy file ini ke .env dan sesuaikan nilai-nilainya:
#   cp .env.example .env
#
# Semua variable dengan prefix HRIS_ akan otomatis terbaca oleh config loader
# dan override nilai dari config/config.yaml
# =============================================================================

# =============================================================================
# SERVER CONFIG
# =============================================================================
HRIS_SERVER_PORT=8080
HRIS_SERVER_MODE=debug                 # debug | release | test
HRIS_SERVER_READ_TIMEOUT=30
HRIS_SERVER_WRITE_TIMEOUT=30

# =============================================================================
# DATABASE CONFIG
# =============================================================================
# Driver: postgres atau mysql
# Untuk MySQL development (Laragon):
HRIS_DATABASE_DRIVER=mysql
HRIS_DATABASE_PLATFORM_HOST=localhost
HRIS_DATABASE_PLATFORM_PORT=3306
HRIS_DATABASE_PLATFORM_DB=hris_platform
HRIS_DATABASE_PLATFORM_USER=root
HRIS_DATABASE_PLATFORM_PASSWORD=
# HRIS_DATABASE_PLATFORM_SSLMODE=disable  # hanya untuk postgres

# Tenant Database (provisioning)
HRIS_DATABASE_TENANT_HOST=localhost
HRIS_DATABASE_TENANT_PORT=3306
HRIS_DATABASE_TENANT_SUPER_USER=root
HRIS_DATABASE_TENANT_SUPER_PASSWORD=

# Untuk PostgreSQL:
# HRIS_DATABASE_DRIVER=postgres
# HRIS_DATABASE_PLATFORM_PORT=5432
# HRIS_DATABASE_PLATFORM_USER=hris
# HRIS_DATABASE_PLATFORM_PASSWORD=hris_secret
# HRIS_DATABASE_PLATFORM_SSLMODE=disable

# Connection Pool
HRIS_DATABASE_MAX_OPEN_CONNS=25
HRIS_DATABASE_MAX_IDLE_CONNS=10
HRIS_DATABASE_CONN_MAX_LIFETIME_MS=3600000

# =============================================================================
# REDIS CONFIG
# =============================================================================
HRIS_REDIS_HOST=localhost
HRIS_REDIS_PORT=6379
HRIS_REDIS_PASSWORD=
HRIS_REDIS_DB=0

# =============================================================================
# JWT CONFIG
# =============================================================================
HRIS_JWT_SECRET=change-this-to-a-strong-secret-in-production
HRIS_JWT_ACCESS_TOKEN_TTL=15           # menit
HRIS_JWT_REFRESH_TOKEN_TTL=24          # jam
HRIS_JWT_ISSUER=hris-platform

# =============================================================================
# LOGGER CONFIG
# =============================================================================
HRIS_LOGGER_LEVEL=debug                # debug | info | warn | error
HRIS_LOGGER_FORMAT=console             # json | console
HRIS_LOGGER_OUTPUT_PATH=stdout

# =============================================================================
# OPENTELEMETRY CONFIG
# =============================================================================
HRIS_OTEL_ENABLED=false
HRIS_OTEL_SERVICE_NAME=hris-platform
HRIS_OTEL_COLLECTOR_ENDPOINT=localhost:4317
HRIS_OTEL_SAMPLE_RATE=0.1

# =============================================================================
# CORS CONFIG
# =============================================================================
HRIS_CORS_ALLOWED_ORIGINS=*
HRIS_CORS_ALLOWED_METHODS=GET,POST,PUT,PATCH,DELETE,OPTIONS
HRIS_CORS_ALLOWED_HEADERS=Origin,Content-Type,Accept,Authorization
HRIS_CORS_ALLOW_CREDENTIALS=true
HRIS_CORS_MAX_AGE=86400

# =============================================================================
# APP INFO
# =============================================================================
HRIS_APP_NAME=HRIS Platform
